# Django Settings
SECRET_KEY=your-secret-key-here-50-characters-long
DEBUG=False
ALLOWED_HOSTS=sustindex-backend.onrender.com,yourdomain.com

# Database (Render will provide this)
DATABASE_URL=postgresql://user:password@host:port/database

# Django Settings Module
DJANGO_SETTINGS_MODULE=sustindex.settings

# Gunicorn Workers
WEB_CONCURRENCY=2

# CORS Settings (Add your frontend URL)
CORS_ALLOWED_ORIGINS=https://sustindex-frontend.onrender.com,https://yourdomain.com
